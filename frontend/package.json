{
  "name": "bruv-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.mjs",
    "copy-vendor-assets": "node scripts/copy-vendor-assets.mjs",
    "predev": "npm run generate-icons && npm run copy-vendor-assets",
    "dev": "vite",
    "prebuild": "npm run generate-icons && npm run copy-vendor-assets",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@tsconfig/svelte": "^5.0.0",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.71.0",
    "lucide-svelte": "^0.577.0",
    "marked": "^17.0.4"
  }
}
